{
  "manifest_version": 3,
  "name": "Shorts Media Keys",
  "version": "1.0",
  "description": "Lets hardware media keys control YouTube Shorts navigation and playback.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "run_at": "document_idle",
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["main.js"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
